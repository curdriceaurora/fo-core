# Docker Compose environment variables
# Copy to .env and update values before running: cp .env.example .env
# Local example values only; keep production secrets out of this file.
# Validation note: this example file is safe for non-doc CI trigger checks.

# Redis password (REQUIRED — used by both redis and file-organizer services)
# "changeme" is for local development only — replace in staging/production.
# Avoid special URI characters (@, :, /, #, %) or percent-encode them.
REDIS_PASSWORD=changeme
