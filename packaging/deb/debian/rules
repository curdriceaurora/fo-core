#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_build:
	# Pre-built binaries are provided; no build step required
	echo "Using pre-built binaries"

override_dh_auto_test:
ifeq (,$(filter nocheck,$(DEB_BUILD_OPTIONS)))
	# Tests are not run during package build because this package ships
	# pre-built binaries and has no source-level build step.  The upstream
	# test suite requires a full Python environment with Ollama models
	# which is not available in the Debian build environment.
	@echo "Skipping tests: pre-built binary package (set DEB_BUILD_OPTIONS=nocheck to silence)"
endif
