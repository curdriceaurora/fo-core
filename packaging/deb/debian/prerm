#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop the file-organizer daemon if it is running
        if command -v systemctl >/dev/null 2>&1; then
            systemctl stop file-organizer.service 2>/dev/null || true
        fi

        # Also try killing by process name as a fallback
        if command -v pkill >/dev/null 2>&1; then
            pkill -f file-organizer-backend 2>/dev/null || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
