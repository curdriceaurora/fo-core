# Byte-compiled Python files
__pycache__/
*.py[cod]
*.pyc

# pytest cache directory
.pytest_cache/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Virtual environment folders
env/
venv/
.venv/

# Ignore log files and temporary files
*.log
*.tmp
*.swp

# Ignore example output files
organized_folder/
operation_log.txt

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# IDE/Editor directories
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Python packaging
*.egg-info/
dist/
build/
# Allow desktop/build/ (Windows manifest and build assets for Tauri)
!desktop/build/
!desktop/build/**
*.egg

# MkDocs build output
site/

# Type checking and linting
.mypy_cache/
.ruff_cache/
.dmypy.json

# Test and sample files
sample_files/
demo_images/
organized_output/
output/

# Test coverage
.coverage
coverage.xml
htmlcov/

# MkDocs build output
site/

# Backup files
*.bak

# Logs
logs/
*.log.*

# CCPM (Claude Code PM) - Keep structure, ignore generated content
.claude/epics/*/updates/
.claude/epics/*/progress/
.claude/epics/*/*.tmp
.claude/settings.json
.claude/settings.local.json

# Test results and coverage
test-results/
coverage/
.nyc_output/
*.lcov

# Jest
.jest-cache/
__snapshots__/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Node modules (if not already there)
node_modules/

# MkDocs build output
site/
.claude/worktrees/
/.worktrees/
