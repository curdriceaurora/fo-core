#!/bin/bash
# Nautilus script: Organize with File Organizer
# Installed to: ~/.local/share/nautilus/scripts/

BACKEND_PORT="${FILE_ORGANIZER_PORT:-8000}"
BACKEND_URL="http://127.0.0.1:${BACKEND_PORT}/api/v1/organize"

# NAUTILUS_SCRIPT_SELECTED_FILE_PATHS contains newline-separated paths
IFS=$'\n'
for path in $NAUTILUS_SCRIPT_SELECTED_FILE_PATHS; do
    if [ -n "$path" ]; then
        # Safely construct JSON payload (escape backslashes and quotes)
        escaped_path=$(printf '%s' "$path" | sed 's/\\/\\\\/g; s/"/\\"/g')
        json_payload="{\"paths\": [\"${escaped_path}\"]}"

        # Try REST API first (if running), fall back to CLI
        if curl -sf -X POST "$BACKEND_URL" \
            -H "Content-Type: application/json" \
            -d "$json_payload" >/dev/null 2>&1; then
            notify-send "File Organizer" "Organizing: $(basename "$path")" 2>/dev/null || true
        elif command -v file-organizer >/dev/null 2>&1; then
            # Fall back to CLI
            file-organizer organize --input "$path" &
        else
            notify-send "File Organizer" "Error: file-organizer not found. Please install it or add it to PATH." 2>/dev/null || true
        fi
    fi
done
