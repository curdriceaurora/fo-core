{
  "name": "local-file-organizer",
  "version": "2.0.0",
  "description": "AI-powered local file management system with privacy-first architecture",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov",
    "test:ci": "jest --coverage --ci && playwright test"
  },
  "keywords": [
    "file-organizer",
    "ai",
    "local-llm",
    "privacy-first"
  ],
  "author": "Local-File-Organizer Contributors",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/dom": "^9.3.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.8",
    "axe-core": "^4.8.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-axe": "^8.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.40.0"
  }
}
